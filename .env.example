# Smart Garbage Chute System - Environment Configuration Template
# Copy this file to .env and fill in production values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_HOST=postgres
DB_PORT=5432
DB_NAME=garbage_chute
DATABASE_URL=postgresql+asyncpg://postgres:change_me_in_production@postgres:5432/garbage_chute

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ============================================================================
# MQTT BROKER CONFIGURATION
# ============================================================================
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_CLIENT_ID=garbage-chute-backend
MQTT_TOPIC_PREFIX=garbage

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
# Server
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=4

# Security
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://garbage-chute.local
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# Admin user
ADMIN_EMAIL=admin@alghurair.local
ADMIN_PASSWORD=change_me_in_production
ADMIN_FULL_NAME=System Administrator

# ============================================================================
# AI SERVICE CONFIGURATION
# ============================================================================
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_PORT=8001
SIMULATION_MODE=true
MODEL_PATH=/models/yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
RTSP_TIMEOUT=30
ACTIVE_STREAMS_MAX=10

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Public API endpoints (accessed from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost/ws
NEXT_PUBLIC_APP_NAME=Smart Garbage Chute
NEXT_PUBLIC_ENVIRONMENT=development

# Backend API (server-side)
NEXT_BACKEND_API_URL=http://backend:8000

# ============================================================================
# NOTIFICATION SERVICE CONFIGURATION
# ============================================================================
# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@alghurair.local

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# WhatsApp (Twilio)
TWILIO_WHATSAPP_NUMBER=

# Firebase Cloud Messaging (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
# Grafana
GRAFANA_PASSWORD=change_me_in_production
GRAFANA_ADMIN_USER=admin

# Prometheus
PROMETHEUS_RETENTION=15d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Loki (optional centralized logging)
LOKI_URL=

# Sentry (optional error tracking)
SENTRY_DSN=

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# SSL/TLS
SSL_CERT_PATH=/etc/nginx/certs/cert.pem
SSL_KEY_PATH=/etc/nginx/certs/key.pem
SSL_ENABLED=false

# Domain
DOMAIN=localhost
DOMAIN_PROD=garbage-chute.yourdomain.com

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=

# ============================================================================
# OPTIONAL INTEGRATIONS
# ============================================================================
# Building Management System Integration
BMS_API_URL=http://bms-server:8080
BMS_API_KEY=

# Weather API
WEATHER_API_URL=
WEATHER_API_KEY=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Telemetry Simulator (for testing without hardware)
TELEMETRY_SIMULATOR_ENABLED=false
TELEMETRY_SIMULATOR_INTERVAL=5

# AI Service Simulation
AI_SIMULATION_ENABLED=true
AI_SIMULATION_GARBAGE_PROBABILITY=0.15

# Database / cache / MQTT
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/garbage_chute
REDIS_URL=redis://redis:6379/0
MQTT_URL=mqtt://mosquitto:1883
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Services
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
API_BASE_URL=http://backend:8000
AI_SERVICE_URL=http://ai-service:8001
NEXT_PUBLIC_API_BASE_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws

# Optional integrations
WHATSAPP_WEBHOOK_URL=
SMS_WEBHOOK_URL=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
BMS_WEBHOOK_URL=
