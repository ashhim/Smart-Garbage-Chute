# =========================================================
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
.pub-cache/
build/
coverage/
.flutter-versions
.metadata

# Flutter generated
**/android/local.properties
**/android/.gradle/
**/android/captures/
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/ephemeral/

# Keep Android raw notification assets
!mobile/android/app/src/main/res/raw/

